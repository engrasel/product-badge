# Copy this file to .env for local development. `shopify app dev` writes
# SHOPIFY_API_KEY / SHOPIFY_API_SECRET / SCOPES / SHOPIFY_APP_URL into your
# shell automatically — you generally only need to set these by hand for a
# production deployment outside the Shopify CLI.

# Shopify app credentials (from the Partner Dashboard / shopify.app.toml)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_orders,write_app_proxy

# The public HTTPS URL this app is reachable at in production.
SHOPIFY_APP_URL=

# SQLite file path. In production, this MUST point at a persistent volume —
# the bundled Dockerfile does not mount one by default, so a fresh container
# with no volume means a fresh, empty database. For anything beyond a single
# long-lived container, consider Postgres/MySQL instead (Prisma supports both;
# update the `provider` in prisma/schema.prisma and re-run migrations).
DATABASE_URL="file:dev.sqlite"

# Optional: only needed if serving the app on a custom domain rather than the
# default *.myshopify.com / cdn app URL.
# SHOP_CUSTOM_DOMAIN=
